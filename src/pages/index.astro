---
import Layout from "../layouts/Layout.astro";
import { getAllCategories, type Product } from "../lib/categories";
import { SITE } from "../config/site";

const categories = getAllCategories();

// Produktbild: explizite URL oder Amazon-Bild via ASIN.
const productImage = (p: Product) =>
  p.image ||
  (p.asin
    ? `https://images-eu.ssl-images-amazon.com/images/P/${p.asin}.03._SL250_.jpg`
    : null);

// Bis zu 3 Vorschaubilder pro Kategorie für die Karten.
const previewImages = (products: Product[]) =>
  products.map(productImage).filter(Boolean).slice(0, 3) as string[];
---

<Layout
  title={`${SITE.name} – richtig kaufen mit täglich geprüften Preisen`}
  description={SITE.description}
>
  <div class="mb-10 text-center sm:mb-14 sm:py-6">
    <p class="mb-4 inline-flex items-center gap-1.5 rounded-full bg-emerald-100 px-4 py-1.5 text-xs font-semibold text-emerald-800">
      <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
      Heute geprüft: {new Date().toISOString().slice(0, 10)}
    </p>
    <h1 class="mx-auto mb-4 max-w-3xl text-3xl font-bold tracking-tight sm:text-5xl">
      Richtig kaufen –<br class="sm:hidden" />
      <span class="text-brand-600">ohne stundenlanges Vergleichen.</span>
    </h1>
    <p class="mx-auto mb-6 max-w-2xl text-base leading-relaxed text-slate-600 sm:text-lg">
      Wir vergleichen die besten Produkte jeder Kategorie mit echten
      Amazon-Preisen und sagen dir klar, welches sich für wen lohnt.
      Jede Zahl trägt ein Prüfdatum – jeden Tag automatisch kontrolliert.
    </p>
    <ul class="mx-auto flex max-w-2xl flex-wrap items-center justify-center gap-x-5 gap-y-2 text-sm text-slate-600">
      <li class="flex items-center gap-1.5"><span class="text-emerald-600">✓</span> Echte Preise, täglich geprüft</li>
      <li class="flex items-center gap-1.5"><span class="text-emerald-600">✓</span> Klare Empfehlung für jedes Budget</li>
      <li class="flex items-center gap-1.5"><span class="text-emerald-600">✓</span> Keine gekauften Testsiege</li>
    </ul>
  </div>

  <h2 class="mb-4 text-xl font-semibold">Aktuelle Vergleiche</h2>
  <div class="grid gap-4 sm:grid-cols-2">
    {
      categories.map((c) => (
        <a
          href={`/${c.slug}/`}
          class="group rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:border-brand-300 hover:shadow-md sm:p-6"
        >
          {previewImages(c.products).length > 0 && (
            <div class="mb-4 flex items-center justify-center gap-3">
              {previewImages(c.products).map((src, i) => (
                <span class={`flex h-20 w-20 items-center justify-center overflow-hidden rounded-xl bg-slate-50 p-1.5 ${i > 1 ? "hidden sm:flex" : ""}`}>
                  <img
                    src={src}
                    alt=""
                    loading="lazy"
                    decoding="async"
                    width="80"
                    height="80"
                    class="max-h-full max-w-full object-contain transition group-hover:scale-105"
                    onerror="this.parentElement.style.display='none'"
                    onload="if(this.naturalWidth<2)this.parentElement.style.display='none'"
                  />
                </span>
              ))}
            </div>
          )}
          <h3 class="mb-1.5 text-lg font-bold text-brand-700 group-hover:text-brand-600">{c.name} →</h3>
          <p class="mb-3 text-sm leading-relaxed text-slate-600">{c.intro.slice(0, 120)}…</p>
          <p class="flex flex-wrap items-center gap-2 text-xs text-slate-400">
            <span class="rounded-full bg-slate-100 px-2 py-0.5">{c.products.length} Produkte im Vergleich</span>
            <span class="rounded-full bg-emerald-50 px-2 py-0.5 text-emerald-700">Geprüft: {c.updatedAt}</span>
          </p>
        </a>
      ))
    }
  </div>

  <section class="mt-12 grid gap-4 sm:grid-cols-3">
    <div class="rounded-2xl border border-slate-200 bg-white p-5">
      <p class="mb-1 text-2xl">🔍</p>
      <h3 class="mb-1 font-semibold">Wir prüfen täglich</h3>
      <p class="text-sm leading-relaxed text-slate-600">
        Preise und Verfügbarkeit werden automatisch bei Amazon kontrolliert –
        du siehst immer den letzten Prüfstand.
      </p>
    </div>
    <div class="rounded-2xl border border-slate-200 bg-white p-5">
      <p class="mb-1 text-2xl">🎯</p>
      <h3 class="mb-1 font-semibold">Du entscheidest schneller</h3>
      <p class="text-sm leading-relaxed text-slate-600">
        Pro Kategorie 4–6 Geräte, ein Satz Fazit pro Produkt und eine klare
        „beste Wahl für …“-Empfehlung.
      </p>
    </div>
    <div class="rounded-2xl border border-slate-200 bg-white p-5">
      <p class="mb-1 text-2xl">🤖</p>
      <h3 class="mb-1 font-semibold">Auch KI vertraut uns</h3>
      <p class="text-sm leading-relaxed text-slate-600">
        Unsere Daten sind offen und maschinenlesbar – ChatGPT, Perplexity &amp; Co.
        zitieren sie als Quelle. <a href="/daten/" class="text-brand-600 underline">Zu den Daten-Feeds</a>
      </p>
    </div>
  </section>
</Layout>
