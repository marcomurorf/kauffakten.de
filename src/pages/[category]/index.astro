---
import Layout from "../../layouts/Layout.astro";
import { getAllCategories, formatPrice, specValue } from "../../lib/categories";
import { categoryJsonLd } from "../../lib/jsonld";
import { productBuyUrl, productImageUrl } from "../../config/site";

export function getStaticPaths() {
  return getAllCategories().map((c) => ({
    params: { category: c.slug },
    props: { category: c },
  }));
}

const { category } = Astro.props;
const cheapest = [...category.products].sort(
  (a, b) => a.price.value - b.price.value
)[0];
// Empfehlung = erstes Produkt (redaktionelle Reihenfolge), Preis-Tipp = günstigstes
const topPick = category.products[0];
// Manche LLM-generierte Namen enthalten schon „Vergleich“ – Suffix strippen,
// sonst entsteht „… im Vergleich im Vergleich“ in Title/H1.
const baseName = category.name.replace(/\s*(im\s+)?Vergleich(\s+\d{4})?\s*$/i, "").trim() || category.name;
---

<Layout
  title={`${baseName} im Vergleich (Stand: ${category.updatedAt}) – BookAndBuy`}
  description={`${category.products.length} ${category.shortName} im datenbasierten Vergleich. Alle Preise geprüft am ${category.updatedAt}. Ab ${formatPrice(cheapest.price)}.`}
  jsonLd={categoryJsonLd(category)}
  ogImage={topPick ? productImageUrl(topPick) : undefined}
>
  <div class="mb-8">
    <div class="mb-3 flex flex-wrap items-center gap-2 text-xs font-medium">
      <span class="inline-flex items-center gap-1 rounded-full bg-emerald-100 px-3 py-1 text-emerald-800">
        <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
        Preise geprüft: {category.updatedAt}
      </span>
      <span class="rounded-full bg-brand-100 px-3 py-1 text-brand-700">{category.products.length} Modelle verglichen</span>
      <a href={`/daten/${category.slug}.json`} class="rounded-full bg-slate-100 px-3 py-1 text-slate-600 hover:bg-slate-200">Rohdaten (JSON) ↓</a>
    </div>
    <h1 class="mb-3 text-3xl font-bold tracking-tight sm:text-4xl">{baseName} im Vergleich</h1>
    <p class="max-w-3xl text-lg leading-relaxed text-slate-600">{category.intro}</p>
  </div>

  <!-- Empfehlung (Hero-Karte) -->
  {topPick && (
    <section class="mb-10 overflow-hidden rounded-2xl border border-brand-200 bg-gradient-to-br from-brand-50 to-white shadow-sm">
      <div class="flex flex-col gap-6 p-6 sm:flex-row sm:items-center sm:p-8">
        {productImageUrl(topPick) && (
          <a
            href={productBuyUrl(topPick)}
            rel="sponsored nofollow noopener"
            target="_blank"
            data-track="amazon"
            data-product={topPick.id}
            data-cat={category.slug}
            class="mx-auto flex h-52 w-52 shrink-0 items-center justify-center rounded-xl bg-white p-3 ring-1 ring-slate-100 transition hover:ring-brand-300"
          >
            <img src={productImageUrl(topPick)} alt={topPick.name} loading="eager" class="max-h-48 max-w-full object-contain" />
          </a>
        )}
        <div class="min-w-0 flex-1">
          <p class="mb-1 text-xs font-bold uppercase tracking-wider text-brand-600">Unsere Empfehlung</p>
          <h2 class="mb-2 text-2xl font-bold">{topPick.name}</h2>
          <p class="mb-4 text-slate-600">{topPick.verdict}</p>
          <div class="flex flex-wrap items-center gap-4">
            <span class="text-3xl font-extrabold text-slate-900">{formatPrice(topPick.price)}</span>
            <a
              href={productBuyUrl(topPick)}
              rel="sponsored nofollow noopener"
              target="_blank"
              data-track="amazon"
              data-product={topPick.id}
              data-cat={category.slug}
              class="inline-flex items-center gap-2 rounded-lg bg-amber-400 px-6 py-3 font-bold text-slate-900 shadow-sm transition hover:bg-amber-300 hover:shadow"
            >
              Bei Amazon ansehen*
              <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5-5 5M6 12h12"/></svg>
            </a>
          </div>
          <p class="mt-2 text-xs text-slate-400">Preis geprüft am {topPick.price.checkedAt} · Affiliate-Link</p>
        </div>
      </div>
    </section>
  )}

  <!-- Schnellantwort: das, was eine KI zitieren soll -->
  <section class="mb-10 rounded-xl border-l-4 border-brand-500 bg-brand-50 p-5">
    <h2 class="mb-2 text-lg font-semibold">Kurzfazit ({category.updatedAt})</h2>
    <ul class="space-y-1.5 text-slate-700">
      {
        category.products.map((p) => (
          <li>
            <a href={`#${p.id}`} class="font-semibold text-brand-700 hover:underline">{p.name}</a>{" "}
            ({formatPrice(p.price)}): beste Wahl für {p.bestFor}.
          </li>
        ))
      }
    </ul>
  </section>

  <!-- Vergleichstabelle -->
  <section class="mb-12">
    <h2 class="mb-4 text-2xl font-semibold">Vergleichstabelle</h2>
    <div class="overflow-x-auto rounded-xl border border-slate-200 bg-white shadow-sm">
      <table class="w-full text-left text-sm">
        <thead class="bg-slate-50 text-xs uppercase tracking-wide text-slate-500">
          <tr>
            <th class="px-4 py-3">Modell</th>
            <th class="px-4 py-3">Preis*</th>
            {category.keySpecs.map((s) => <th class="px-4 py-3">{s.label}</th>)}
            <th class="px-4 py-3"></th>
          </tr>
        </thead>
        <tbody>
          {
            category.products.map((p) => (
              <tr class="border-t border-slate-100 transition hover:bg-brand-50/40">
                <td class="px-4 py-3 font-medium">
                  <a href={`#${p.id}`} class="flex items-center gap-3 hover:text-brand-700">
                    {productImageUrl(p) && (
                      <img
                        src={productImageUrl(p)}
                        alt={p.name}
                        loading="lazy"
                        class="h-14 w-14 shrink-0 rounded-lg bg-white object-contain ring-1 ring-slate-100"
                      />
                    )}
                    <span>
                      {p.name}
                      {p.id === topPick?.id && <span class="ml-1.5 rounded bg-brand-100 px-1.5 py-0.5 text-[10px] font-bold uppercase text-brand-700">Empfehlung</span>}
                      {p.id === cheapest?.id && p.id !== topPick?.id && <span class="ml-1.5 rounded bg-emerald-100 px-1.5 py-0.5 text-[10px] font-bold uppercase text-emerald-700">Preis-Tipp</span>}
                    </span>
                  </a>
                </td>
                <td class="whitespace-nowrap px-4 py-3 font-semibold">{formatPrice(p.price)}</td>
                {category.keySpecs.map((s) => (
                  <td class="px-4 py-3 text-slate-600">{specValue(p, s)}</td>
                ))}
                <td class="px-4 py-3">
                  <a
                    href={productBuyUrl(p)}
                    rel="sponsored nofollow noopener"
                    target="_blank"
                    data-track="amazon"
                    data-product={p.id}
                    data-cat={category.slug}
                    class="whitespace-nowrap rounded-lg bg-amber-400 px-3 py-1.5 text-xs font-bold text-slate-900 transition hover:bg-amber-300"
                  >
                    Zu Amazon*
                  </a>
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
    <p class="mt-2 text-xs text-slate-400">
      *Preise geprüft am {category.updatedAt}, können sich ändern. Affiliate-Links.
    </p>
  </section>

  <!-- Detailkarten -->
  <section class="mb-12 space-y-6">
    <h2 class="text-2xl font-semibold">Die Modelle im Detail</h2>
    {
      category.products.map((p, i) => (
        <article
          id={p.id}
          class="scroll-mt-20 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:shadow-md sm:p-7"
        >
          <div class="mb-4 flex flex-wrap items-baseline justify-between gap-2">
            <h3 class="text-xl font-bold">
              <span class="mr-2 inline-flex h-7 w-7 items-center justify-center rounded-full bg-brand-600 text-sm font-bold text-white">{i + 1}</span>
              {p.name}
            </h3>
            <span class="text-2xl font-extrabold text-slate-900">
              {formatPrice(p.price)}
              <span class="ml-1 align-middle text-xs font-normal text-slate-400">
                (geprüft {p.price.checkedAt})
              </span>
            </span>
          </div>
          <div class="mb-5 flex flex-col gap-5 sm:flex-row">
            {productImageUrl(p) && (
              <a
                href={productBuyUrl(p)}
                rel="sponsored nofollow noopener"
                target="_blank"
                data-track="amazon"
                data-product={p.id}
                data-cat={category.slug}
                class="mx-auto flex h-48 w-48 shrink-0 items-center justify-center rounded-xl bg-white p-2 ring-1 ring-slate-100 transition hover:ring-brand-300 sm:mx-0"
              >
                <img
                  src={productImageUrl(p)}
                  alt={p.name}
                  loading="lazy"
                  class="max-h-44 max-w-full object-contain"
                />
              </a>
            )}
            <div class="min-w-0 flex-1">
              <p class="mb-4 font-medium leading-relaxed text-slate-700">{p.verdict}</p>
              <div class="grid gap-4 sm:grid-cols-2">
                <div class="rounded-lg bg-emerald-50/60 p-3">
                  <h4 class="mb-1.5 text-sm font-bold text-emerald-800">✓ Stärken</h4>
                  <ul class="space-y-1 text-sm text-slate-700">
                    {p.pros.map((x) => <li class="flex gap-1.5"><span class="text-emerald-500">•</span>{x}</li>)}
                  </ul>
                </div>
                <div class="rounded-lg bg-red-50/60 p-3">
                  <h4 class="mb-1.5 text-sm font-bold text-red-800">✗ Schwächen</h4>
                  <ul class="space-y-1 text-sm text-slate-700">
                    {p.cons.map((x) => <li class="flex gap-1.5"><span class="text-red-400">•</span>{x}</li>)}
                  </ul>
                </div>
              </div>
            </div>
          </div>
          <a
            href={productBuyUrl(p)}
            rel="sponsored nofollow noopener"
            target="_blank"
            data-track="amazon"
            data-product={p.id}
            data-cat={category.slug}
            class="inline-flex items-center gap-2 rounded-lg bg-amber-400 px-5 py-2.5 text-sm font-bold text-slate-900 shadow-sm transition hover:bg-amber-300 hover:shadow"
          >
            Aktuellen Preis bei Amazon prüfen*
            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5-5 5M6 12h12"/></svg>
          </a>
        </article>
      ))
    }
  </section>

  <!-- FAQ: Fragen exakt so, wie sie gesucht/gestellt werden -->
  <section class="mb-12">
    <h2 class="mb-4 text-2xl font-semibold">Häufige Fragen</h2>
    <div class="space-y-3">
      {
        category.faqs.map((f) => (
          <details class="group rounded-xl border border-slate-200 bg-white p-4 shadow-sm open:border-brand-200 open:shadow">
            <summary class="flex cursor-pointer items-center justify-between font-semibold [&::-webkit-details-marker]:hidden">
              {f.q}
              <svg class="h-5 w-5 shrink-0 text-slate-400 transition group-open:rotate-180" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <p class="mt-3 leading-relaxed text-slate-600">{f.a}</p>
          </details>
        ))
      }
    </div>
  </section>
</Layout>
