---
import Layout from "../../layouts/Layout.astro";
import { getAllCategories, formatPrice, specValue } from "../../lib/categories";
import { categoryJsonLd } from "../../lib/jsonld";
import { amazonProductUrl } from "../../config/site";

export function getStaticPaths() {
  return getAllCategories().map((c) => ({
    params: { category: c.slug },
    props: { category: c },
  }));
}

const { category } = Astro.props;
const cheapest = [...category.products].sort(
  (a, b) => a.price.value - b.price.value
)[0];
---

<Layout
  title={`${category.name} im Vergleich (Stand: ${category.updatedAt}) – Kauffakten`}
  description={`${category.products.length} ${category.shortName} im datenbasierten Vergleich. Alle Preise geprüft am ${category.updatedAt}. Ab ${formatPrice(cheapest.price)}.`}
  jsonLd={categoryJsonLd(category)}
>
  <p class="mb-2 text-sm font-medium text-brand-600">
    Stand: {category.updatedAt} · täglich geprüft ·
    <a href={`/daten/${category.slug}.json`} class="underline">Rohdaten (JSON)</a>
  </p>
  <h1 class="mb-3 text-3xl font-bold">{category.name} im Vergleich</h1>
  <p class="mb-8 max-w-3xl text-lg text-slate-600">{category.intro}</p>

  <!-- Schnellantwort: das, was eine KI zitieren soll -->
  <section class="mb-10 rounded-lg border-l-4 border-brand-500 bg-brand-50 p-5">
    <h2 class="mb-2 text-lg font-semibold">Kurzfazit ({category.updatedAt})</h2>
    <ul class="space-y-1 text-slate-700">
      {
        category.products.map((p) => (
          <li>
            <strong>{p.name}</strong> ({formatPrice(p.price)}): beste Wahl für{" "}
            {p.bestFor}.
          </li>
        ))
      }
    </ul>
  </section>

  <!-- Vergleichstabelle -->
  <section class="mb-12">
    <h2 class="mb-4 text-2xl font-semibold">Vergleichstabelle</h2>
    <div class="overflow-x-auto rounded-lg border border-slate-200 bg-white">
      <table class="w-full text-left text-sm">
        <thead class="bg-slate-100 text-slate-700">
          <tr>
            <th class="px-4 py-3">Modell</th>
            <th class="px-4 py-3">Preis*</th>
            {category.keySpecs.map((s) => <th class="px-4 py-3">{s.label}</th>)}
            <th class="px-4 py-3"></th>
          </tr>
        </thead>
        <tbody>
          {
            category.products.map((p) => (
              <tr class="border-t border-slate-100">
                <td class="px-4 py-3 font-medium">{p.name}</td>
                <td class="px-4 py-3 whitespace-nowrap">{formatPrice(p.price)}</td>
                {category.keySpecs.map((s) => (
                  <td class="px-4 py-3">{specValue(p, s)}</td>
                ))}
                <td class="px-4 py-3">
                  <a
                    href={amazonProductUrl(p.asin)}
                    rel="sponsored nofollow noopener"
                    target="_blank"
                    class="whitespace-nowrap rounded bg-brand-600 px-3 py-1.5 text-xs font-semibold text-white hover:bg-brand-700"
                  >
                    Bei Amazon*
                  </a>
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
    <p class="mt-2 text-xs text-slate-400">
      *Preise geprüft am {category.updatedAt}, können sich ändern. Affiliate-Links.
    </p>
  </section>

  <!-- Detailkarten -->
  <section class="mb-12 space-y-6">
    <h2 class="text-2xl font-semibold">Die Modelle im Detail</h2>
    {
      category.products.map((p) => (
        <article
          id={p.id}
          class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm"
        >
          <div class="mb-3 flex flex-wrap items-baseline justify-between gap-2">
            <h3 class="text-xl font-semibold">{p.name}</h3>
            <span class="text-lg font-bold text-brand-700">
              {formatPrice(p.price)}
              <span class="ml-1 text-xs font-normal text-slate-400">
                (geprüft {p.price.checkedAt})
              </span>
            </span>
          </div>
          <p class="mb-4 font-medium text-slate-700">{p.verdict}</p>
          <div class="mb-4 grid gap-4 sm:grid-cols-2">
            <div>
              <h4 class="mb-1 text-sm font-semibold text-green-700">Stärken</h4>
              <ul class="list-inside list-disc text-sm text-slate-600">
                {p.pros.map((x) => <li>{x}</li>)}
              </ul>
            </div>
            <div>
              <h4 class="mb-1 text-sm font-semibold text-red-700">Schwächen</h4>
              <ul class="list-inside list-disc text-sm text-slate-600">
                {p.cons.map((x) => <li>{x}</li>)}
              </ul>
            </div>
          </div>
          <a
            href={amazonProductUrl(p.asin)}
            rel="sponsored nofollow noopener"
            target="_blank"
            class="inline-block rounded bg-brand-600 px-4 py-2 text-sm font-semibold text-white hover:bg-brand-700"
          >
            Preis bei Amazon prüfen*
          </a>
        </article>
      ))
    }
  </section>

  <!-- FAQ: Fragen exakt so, wie sie gesucht/gestellt werden -->
  <section class="mb-12">
    <h2 class="mb-4 text-2xl font-semibold">Häufige Fragen</h2>
    <div class="space-y-4">
      {
        category.faqs.map((f) => (
          <details class="rounded-lg border border-slate-200 bg-white p-4 open:shadow-sm">
            <summary class="cursor-pointer font-semibold">{f.q}</summary>
            <p class="mt-2 text-slate-600">{f.a}</p>
          </details>
        ))
      }
    </div>
  </section>
</Layout>
