---
import "../styles/global.css";
import { SITE } from "../config/site";

interface Props {
  title: string;
  description: string;
  jsonLd?: object;
  canonical?: string;
  noindex?: boolean;
  ogImage?: string;
}

const { title, description, jsonLd, canonical, noindex, ogImage } = Astro.props;
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, SITE.domain).href;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex" />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={SITE.name} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title={`${SITE.name} – Aktualisierte Produktvergleiche`} href="/rss.xml" />
    {
      jsonLd && (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(jsonLd)}
        />
      )
    }
  </head>
  <body class="min-h-screen bg-slate-50 text-slate-900 antialiased">
    <header class="sticky top-0 z-40 border-b border-slate-200/70 bg-white/90 backdrop-blur">
      <div class="mx-auto flex max-w-5xl items-center justify-between px-4 py-3.5">
        <a href="/" class="text-xl font-bold tracking-tight text-brand-900">BookAndBuy<span class="text-brand-500">.de</span></a>
        <span class="hidden items-center gap-1.5 text-sm text-slate-500 sm:flex">
          <svg class="h-4 w-4 text-emerald-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
          {SITE.tagline}
        </span>
      </div>
    </header>
    <main class="mx-auto max-w-5xl px-4 py-8">
      <slot />
    </main>
    <footer class="mt-16 border-t border-slate-200 bg-white">
      <div class="mx-auto max-w-5xl px-4 py-8 text-sm text-slate-500">
        <p class="mb-2">
          Alle Preisangaben mit Prüfdatum, ohne Gewähr. Als Amazon-Partner verdienen
          wir an qualifizierten Verkäufen. Links zu Amazon sind Affiliate-Links.
        </p>
        <p class="mb-4">
          Rohdaten frei nutzbar mit Quellenangabe:
          <a href="/daten/" class="underline hover:text-brand-600">JSON-Feeds &amp; Daten-Lizenz</a>
          · <a href="/rss.xml" class="underline hover:text-brand-600">RSS-Feed</a>
          · <a href="/llms.txt" class="underline hover:text-brand-600">llms.txt</a>
        </p>
        <nav class="flex gap-4">
          <a href="/impressum/" class="hover:text-brand-600">Impressum</a>
          <a href="/datenschutz/" class="hover:text-brand-600">Datenschutz</a>
        </nav>
      </div>
    </footer>
    <script>
      // Anonymes Klick-Tracking (keine Cookies, keine personenbezogenen Daten):
      // registriert nur, WELCHER Produktlink geklickt wurde.
      document.addEventListener("click", (e) => {
        const a = (e.target as Element).closest?.("a[data-track]");
        if (!a) return;
        const payload = JSON.stringify({
          t: "click",
          k: a.getAttribute("data-track"),
          p: a.getAttribute("data-product"),
          c: a.getAttribute("data-cat"),
          path: location.pathname,
          ref: document.referrer.slice(0, 200),
        });
        navigator.sendBeacon?.("/t", payload);
      });
    </script>
  </body>
</html>
